mixin alert-success(time)
    - if (messages.success)
            .messages.info
                div(
                    class="alert alert-success"
                    show-alert
                    data-time=time
                ) #{messages.success} <span close-alert>x</span>

mixin alert-success(time)
    - if (messages.error)
            .messages.info
                div(
                    class="alert alert-success"
                    show-alert
                    data-time=time
                ) #{messages.success} <span close-alert>x</span>

